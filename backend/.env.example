NODE_ENV=development
PORT=3000
API_PREFIX=/api
REQUEST_TIMEOUT_MS=7000
MIGRATION_CONCURRENCY=8
# Puedes usar MYSQL_* o DB_*
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=simulacro_dbb
MYSQL_CONNECTION_LIMIT=10
# Alias alternativos compatibles
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=simulacro_dbb
DB_CONNECTION_LIMIT=10
DB_SOCKET=
MONGO_URI=mongodb://127.0.0.1:27017
MONGO_DATABASE=simulacro_dbb
MONGO_CLIENT_HISTORIES_COLLECTION=client_histories
